# ====================================================
# PrivateClaw — Environment Variables
# ====================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ====================================================

# --- Aleo Deployment (Leo Contract) ---
# Your Aleo account private key — keep this SECRET
# Generate one at: https://provable.tools/account
# Get testnet credits at: https://faucet.aleo.org
ALEO_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# --- Supabase (Database) ---
# Find these in your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# --- Cloudflare AI (Trading Assistant) ---
# Create a token at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
